# Reference only: neither Make nor patchwork-api loads .env automatically.
# Export these values or prefix the command that starts the server.

# Directory the local dashboard may scan. Paths outside this root are rejected.
PATCHWORK_WORKSPACE_ROOT=.

# Bind locally by default. Use an authenticated reverse proxy before exposing it.
PATCHWORK_HOST=127.0.0.1
PATCHWORK_PORT=8765

# Reject excess source/URL scans immediately so health and dashboard traffic stay responsive.
PATCHWORK_MAX_CONCURRENT_SCANS=4

# Browser origins allowed to call the API during local development.
PATCHWORK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
